{
  "expo": {
    "name": "nada",
    "slug": "nada",
    "scheme": "nada",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/10d992df-8df3-4107-a524-f0f16ba7ad93"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nada.shop",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "nada can weave a few of your recent photos into your calm feed. They stay on your device and are never uploaded."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F4EE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-image",
      [
        "expo-media-library",
        {
          "photosPermission": "nada can weave a few of your recent photos into your calm feed. They stay on your device and are never uploaded."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "backgroundColor": "#F7F4EE"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "10d992df-8df3-4107-a524-f0f16ba7ad93"
      }
    },
    "owner": "antneee"
  }
}
